# Resend notification for diagnostic review requests.
# Leave empty in local development to use mock logging in the API route.
# Evidence uploads are attached to the notification email in the current prototype.
# Keep total upload size small; for production, store files in R2/S3 and email signed links.
NEXT_PUBLIC_SITE_URL=https://www.qqbytran.com
RESEND_API_KEY=
LEAD_NOTIFICATION_EMAIL=
LEAD_FROM_EMAIL="Global Bridge Compliance <onboarding@resend.dev>"

# Local Brain article production fallback env vars.
# Preferred: configure provider/API key in the local Streamlit console.
LOCAL_BRAIN_PROVIDER=openai
LOCAL_BRAIN_API_KEY=
LOCAL_BRAIN_MODEL=gpt-4o-mini
LOCAL_BRAIN_BASE_URL=https://api.openai.com/v1
