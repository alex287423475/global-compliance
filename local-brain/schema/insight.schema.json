{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Compliance SEO Insight Article V2",
  "type": "object",
  "required": [
    "slug",
    "title",
    "zhTitle",
    "category",
    "market",
    "riskLevel",
    "updatedAt",
    "metaTitle",
    "metaDescription",
    "summary",
    "zhSummary",
    "dek",
    "zhDek",
    "bodyMarkdown",
    "zhBodyMarkdown",
    "toc",
    "intelligenceCards",
    "faq",
    "relatedKeywords",
    "redlineTerms"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 20
    },
    "zhTitle": {
      "type": "string",
      "minLength": 8
    },
    "category": {
      "type": "string",
      "enum": [
        "Payment Risk",
        "Marketplace Appeal",
        "Market Entry",
        "Supply Chain",
        "IP Defense",
        "Crisis PR",
        "Capital Documents",
        "B2B Contracts",
        "Tax & Audit",
        "Data Privacy"
      ]
    },
    "market": {
      "type": "string",
      "minLength": 2
    },
    "riskLevel": {
      "type": "string",
      "enum": ["Critical", "High", "Medium"]
    },
    "updatedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "metaTitle": {
      "type": "string",
      "minLength": 20,
      "maxLength": 80
    },
    "metaDescription": {
      "type": "string",
      "minLength": 100,
      "maxLength": 180
    },
    "dek": {
      "type": "string",
      "minLength": 40
    },
    "zhDek": {
      "type": "string",
      "minLength": 20
    },
    "summary": {
      "type": "string",
      "minLength": 120
    },
    "zhSummary": {
      "type": "string",
      "minLength": 60
    },
    "bodyMarkdown": {
      "type": "string",
      "minLength": 4000
    },
    "zhBodyMarkdown": {
      "type": "string",
      "minLength": 2000
    },
    "toc": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "label", "zhLabel", "level"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "label": {
            "type": "string",
            "minLength": 4
          },
          "zhLabel": {
            "type": "string",
            "minLength": 2
          },
          "level": {
            "type": "integer",
            "minimum": 2,
            "maximum": 3
          }
        }
      }
    },
    "intelligenceCards": {
      "type": "array",
      "minItems": 3,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["label", "zhLabel", "finding", "zhFinding", "evidence", "zhEvidence", "action", "zhAction", "severity"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 4
          },
          "zhLabel": {
            "type": "string",
            "minLength": 2
          },
          "finding": {
            "type": "string",
            "minLength": 60
          },
          "zhFinding": {
            "type": "string",
            "minLength": 30
          },
          "evidence": {
            "type": "string",
            "minLength": 40
          },
          "zhEvidence": {
            "type": "string",
            "minLength": 20
          },
          "action": {
            "type": "string",
            "minLength": 40
          },
          "zhAction": {
            "type": "string",
            "minLength": 20
          },
          "severity": {
            "type": "string",
            "enum": ["Critical", "High", "Medium", "Watch"]
          }
        }
      }
    },
    "faq": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["question", "answer", "zhQuestion", "zhAnswer"],
        "properties": {
          "question": {
            "type": "string",
            "minLength": 12
          },
          "answer": {
            "type": "string",
            "minLength": 80
          },
          "zhQuestion": {
            "type": "string",
            "minLength": 6
          },
          "zhAnswer": {
            "type": "string",
            "minLength": 40
          }
        }
      }
    },
    "relatedKeywords": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "redlineTerms": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "introduction": {
      "type": "string",
      "minLength": 120
    },
    "zhIntroduction": {
      "type": "string",
      "minLength": 60
    },
    "keyTakeaways": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 12
      }
    },
    "zhKeyTakeaways": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 6
      }
    },
    "conclusion": {
      "type": "string",
      "minLength": 120
    },
    "zhConclusion": {
      "type": "string",
      "minLength": 60
    }
  }
}
